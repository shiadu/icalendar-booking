PORT=3000
BOOKING_TIMEZONE=America/New_York
BOOKING_DAYS=2,3,4
BOOKING_START_HOUR=13
BOOKING_END_HOUR=18

# Scheduling controls
MIN_NOTICE_HOURS=2
BUFFER_MINUTES=10
MAX_MEETINGS_PER_DAY=12

# Branding
BRAND_NAME=iCalendar
HOST_NAME=Shia Du

# Optional: secure machine-to-machine agent endpoints
# If set, pass Authorization: Bearer <AGENT_API_KEY> to /api/agent/* routes
AGENT_API_KEY=

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Optional custom confirmation email (in addition to Google invite)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=iCalendar
MAIL_FROM_EMAIL=
